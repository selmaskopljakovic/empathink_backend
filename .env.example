# Required
# WARNING: Never commit real API keys to version control!
# Use a .env file locally (listed in .gitignore) and GCP Secret Manager in production.
GEMINI_API_KEY=your-gemini-api-key

# Firebase Auth (one of these is required for token verification)
# Option A: Service account key file (local development)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# Option B: Project ID only (Cloud Run provides credentials automatically)
FIREBASE_PROJECT_ID=empathink-66fb2

# Optional
ENVIRONMENT=development          # "development" or "production"
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
FACE_BACKEND=deepface            # "deepface" or "fer"
PORT=8080
CORS_ORIGINS=                    # Extra allowed origins (comma-separated)
ALLOW_ANONYMOUS_DEV=false        # Set "true" to skip auth in development
